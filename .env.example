# Container timezone
TZ=Europe/Moscow
AWS_REGION=us-east-1

# ---------------------------------------------------------------- MinIO (S3)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_HOST_PORT_API=39010
MINIO_HOST_PORT_CONSOLE=39011
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_RAW_FILES_BUCKET=raw-files

# --------------------------------------------------- Iceberg REST + catalog DB
POSTGRES_DB=iceberg
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg
ICEBERG_REST_HOST_PORT=38181

# ---------------------------------------------------------------------- Trino
TRINO_HOST_PORT=38080

# -------------------------------------------------------------------- Prefect
PREFECT_HOST_PORT=34200
PREFECT_UI_API_URL=/api
PREFECT_POSTGRES_DB=prefect
PREFECT_POSTGRES_USER=prefect
PREFECT_POSTGRES_PASSWORD=prefect
# Empty = no UI/API auth (simplest for local). Set "user:pass" to require it.
PREFECT_SERVER_API_AUTH_STRING=

# -------------------------------------------------------------------- LiteLLM
LITELLM_HOST_PORT=34000
LITELLM_MASTER_KEY=sk-master-dev-change-me
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=litellm
LITELLM_DATABASE_URL=postgresql://litellm:litellm@litellm-db:5432/litellm
# GigaChat (the only model group) — base64 client_id:secret. Blank leaves the
# proxy up but gigachat-lite returns 401 until set.
LITELLM_GIGACHAT_CREDENTIALS=
LITELLM_GIGACHAT_SCOPE=GIGACHAT_API_B2B
LITELLM_GIGACHAT_VERIFY_SSL_CERTS=false
LITELLM_MAX_STRING_LENGTH_PROMPT_IN_DB=50000
LITELLM_DISABLE_SCHEMA_UPDATE=False

# -------------------------------------------------------------------- Grafana
GRAFANA_HOST_PORT=33000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# mcp-grafana (Grafana MCP server) authenticates to Grafana with the admin
# creds above via basic auth — nothing extra to configure.
