# Container timezone
TZ=Europe/Moscow
AWS_REGION=us-east-1

# ---------------------------------------------------------------- MinIO (S3)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_HOST_PORT_API=39010
MINIO_HOST_PORT_CONSOLE=39011
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_RAW_FILES_BUCKET=raw-files
# Exported evaluation datasets (eval publish flow writes here).
MINIO_EVAL_DATASETS_BUCKET=eval-datasets

# --------------------------------------------------- Iceberg REST + catalog DB
POSTGRES_DB=iceberg
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg
ICEBERG_REST_HOST_PORT=38181

# ---------------------------------------------------------------------- Trino
TRINO_HOST_PORT=38080

# -------------------------------------------------------------------- Prefect
PREFECT_HOST_PORT=34200
PREFECT_UI_API_URL=/api
PREFECT_POSTGRES_DB=prefect
PREFECT_POSTGRES_USER=prefect
PREFECT_POSTGRES_PASSWORD=prefect
# Prefect UI/API credentials as "user:pass". The worker reuses this value as its
# client-side PREFECT_API_AUTH_STRING.
# MUST NOT be empty. The server turns its auth middleware on whenever the setting
# is present at all (`if auth_string is not None`), while the client only sends the
# header when the value is truthy — so an empty string means every API call gets
# 401 while GET /api/health stays exempt and the container still reports healthy.
# To genuinely run without auth, drop the variable from the prefect service in
# docker-compose.yml rather than blanking it here.
PREFECT_SERVER_API_AUTH_STRING=admin:admin
# Work pool the worker serves. Created on first worker start.
PREFECT_WORK_POOL=default-pool

# -------------------------------------------------------------------- LiteLLM
LITELLM_HOST_PORT=34000
LITELLM_MASTER_KEY=sk-master-dev-change-me
LITELLM_DB_NAME=litellm
LITELLM_DB_USER=litellm
LITELLM_DB_PASSWORD=litellm
LITELLM_DATABASE_URL=postgresql://litellm:litellm@litellm-db:5432/litellm
# GigaChat credentials, base64 client_id:secret — shared by the gigachat-lite,
# gigachat-pro and gigachat-max groups. Blank leaves the proxy up but all three
# return 401 until set.
LITELLM_GIGACHAT_CREDENTIALS=
LITELLM_GIGACHAT_SCOPE=GIGACHAT_API_B2B
LITELLM_GIGACHAT_VERIFY_SSL_CERTS=false
# A GigaChat Lightning served locally and reached over a tunnel, exposed by the
# proxy as the model group `gigachat-lightning-local`.
# NOT 127.0.0.1: inside the LiteLLM container that is the container itself. A
# tunnel terminating on the host is reached at host.docker.internal, which the
# compose service maps to the host gateway.
LOCAL_LLM_BASE_URL=http://host.docker.internal:29105/v1
# Must stay non-empty even where the local server ignores it — LiteLLM treats a
# falsy api_key as unset and falls back to OPENAI_API_KEY.
LOCAL_LLM_API_KEY=sk-local-noauth

LITELLM_MAX_STRING_LENGTH_PROMPT_IN_DB=50000
LITELLM_DISABLE_SCHEMA_UPDATE=False

# --------------------------------------------------------------------- GigaAM
# Self-hosted ASR wrapper (ai/infra/gigaam), exposed to LiteLLM as
# `transcription-gigaam`. CPU-only: the image is large and the first boot
# downloads model weights into the gigaam-cache volume.
GIGAAM_HOST_PORT=38103
GIGAAM_MODEL=v3_e2e_rnnt
GIGAAM_THREADS=3
# HuggingFace token. Required for longform transcription: the pyannote VAD
# weights are a gated repo, so you must accept its terms on HF with this account
# first. Empty = short-audio transcription still works, longform fails.
GIGAAM_HF_TOKEN=
# How LiteLLM reaches the wrapper. The wrapper ignores the key, but it must not
# be empty: LiteLLM treats a falsy api_key as unset and falls back to
# OPENAI_API_KEY, which this project does not define.
LITELLM_GIGAAM_BASE_URL=http://gigaam:8000/v1
LITELLM_GIGAAM_MASTER_KEY=sk-gigaam-noauth

# -------------------------------------------------------------------- Grafana
GRAFANA_HOST_PORT=33000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
# mcp-grafana (Grafana MCP server) authenticates to Grafana with the admin
# creds above via basic auth — nothing extra to configure.

# ---------------------------------------------------------------- Analysis
# Proxy model groups the flows ask for — not provider model ids. Available:
# gigachat-lite / gigachat-pro / gigachat-max / gigachat-lightning-local for
# chat, transcription-gigaam for speech. Changing these and restarting the
# worker is enough; deployments carry no model parameter to override them.
ANALYSIS_CHAT_MODEL=gigachat-lite
ANALYSIS_WHISPER_MODEL=transcription-gigaam

# ----------------------------------------------------------- Analysis prompts
# Seller identity used by the ASR vocabulary hint and the speaker-role detector.
# NB: the analyser prompts in ai/reports/ carry the name inline (Russian declines
# it), so changing this alone leaves them grading a different name — see
# ai/shared/branding.py.
SELLER_BRAND=Девелопер
# Optional comma-separated project names fed to the ASR hint. Empty by default:
# a real catalogue would tie this stand to one company's portfolio.
SELLER_PROJECTS=
